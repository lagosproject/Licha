# Licha (TwitchChatTTS) - Environment Configuration Template
# Copy this file to '.env' or add these keys to your 'local.properties' / system environment variables.
# NEVER commit the actual '.env' or your secrets to version control!

# Twitch Developer Configuration
# Obtain these by registering an application at https://dev.twitch.tv/console
TWITCH_CLIENT_ID=<YOUR_TWITCH_CLIENT_ID_HERE>

# (Optional) Twitch Client Secret - Note: client-side Android applications should generally
# use the OAuth Implicit Grant flow or Authorization Code flow with PKCE, which does not require
# a client secret. Only define this if you run a custom backend redirect server.
TWITCH_CLIENT_SECRET=<YOUR_TWITCH_CLIENT_SECRET_HERE>

# Redirect URI configured in your Twitch Console (usually http://localhost or a custom scheme)
TWITCH_REDIRECT_URI=http://localhost
